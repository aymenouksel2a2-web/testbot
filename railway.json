{
  "$schema": "https://railway.app/json-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "pkgs": ["python311", "nodejs"],
          "cmds": ["playwright install --with-deps chromium"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python3 main.py",
    "restartPolicy": "ON_FAILURE"
  }
}
