BOT_TOKEN=123456:telegram_bot_token
RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Optional login if Gratisfy requires it
LOGIN_EMAIL=
LOGIN_PASSWORD=

# Visual model selector in the page
TARGET_MODEL=Grok Uncensored

# API extraction fix
GRATISFY_SEND_MODE=capture
GRATISFY_API_URL=https://gratisfy.xyz/api/chat
GRATISFY_PROVIDER=navy
GRATISFY_MODEL_ID=grok-uncensored
API_TIMEOUT=120

# Runtime options
STREAM_INTERVAL=3
HEADLESS=true
LOG_LEVEL=INFO
